PORT=3001
ENABLE_SOAP=true
ENABLE_DEMO_MODE=false
ENABLE_USER_CREATION=false

# Matches the working API-Tool.ps1 defaults. Override per environment with
# SOAP_PASSWORD_PREPROD, SOAP_USERNAME_TEMPLATE_UAT, etc. when needed.
SOAP_ENDPOINT_TEMPLATE=https://{env}.account.oup.com/api/edu/open/eac-web-services/
SOAP_USERNAME_TEMPLATE={env}_test
SOAP_PASSWORD=Oxford123
SOAP_SYSTEM_PREFIX=elt_
SOAP_TYPE_ID=isbn

CONNECT_TIMEOUT_MS=3000
REQUEST_TIMEOUT_MS=15000
RETRY_TIMEOUT_MS=2000
